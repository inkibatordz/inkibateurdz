# Postgres (Supabase). Use the connection pooler URL if you are on IPv4-only networks.
# Append sslmode=require if needed, e.g. .../postgres?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional: force SSL for hosted DB (default: auto-detect supabase.co host)
# DATABASE_SSL=require

# Gmail for OTP emails (optional for local dev if you skip OTP flow)
EMAIL_USER=
EMAIL_PASS=

# API port
PORT=3001

# Frontend → Express (Vite)
VITE_API_URL=http://localhost:3001
